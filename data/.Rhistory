"Disagree" = 4, "Strongly disagree" = 5),
label = "Level of agreement with the belief that traditional gender roles are best for everyone involved")
# ============================================================
# TABLE 20. Police Abuse
# ============================================================
gss$polhitok <- labelled(gss$polhitok,
labels = c("Yes" = 1, "No" = 2),
label = "Support of police violence for some reason")
gss$polabuse <- labelled(gss$polabuse,
labels = c("Yes" = 1, "No" = 2),
label = "Support of police violence if citizen said vulgar or obscene things")
gss$polmurdr <- labelled(gss$polmurdr,
labels = c("Yes" = 1, "No" = 2),
label = "Support of police violence if citizen questioned as murder suspect")
gss$polescap <- labelled(gss$polescap,
labels = c("Yes" = 1, "No" = 2),
label = "Support of police violence if citizen attempting to escape custody")
gss$polattak <- labelled(gss$polattak,
labels = c("Yes" = 1, "No" = 2),
label = "Support of police violence if citizen attacking policeman with fists")
# ============================================================
# TABLE 21. Miscellaneous
# ============================================================
gss$fear <- labelled(gss$fear,
labels = c("Yes" = 1, "No" = 2),
label = "Sense of neighborhood security")
gss$cappun <- labelled(gss$cappun,
labels = c("Favor" = 1, "Oppose" = 2),
label = "Views on death penalty")
gss$gunlaw <- labelled(gss$gunlaw,
labels = c("Favor" = 1, "Oppose" = 2),
label = "Views on gun control measures")
gss$owngun <- labelled(gss$owngun,
labels = c("Yes" = 1, "No" = 2, "Refused" = 3),
label = "Ownership of gun")
gss$courts <- labelled(gss$courts,
labels = c("Too harshly" = 1, "Not harshly enough" = 2, "About right" = 3),
label = "Views on criminal justice adequacy")
gss$homosex <- labelled(gss$homosex,
labels = c("Always wrong" = 1, "Almost always wrong" = 2,
"Wrong only sometimes" = 3, "Not wrong at all" = 4),
label = "Support level for sexual relations between two adults of the same sex")
gss$grass <- labelled(gss$grass,
labels = c("Should be legal" = 1, "Should not be legal" = 2),
label = "Views on legality of marijuana")
gss$sexeduc <- labelled(gss$sexeduc,
labels = c("Favor" = 1, "Oppose" = 2),
label = "Views on sex education in public schools")
gss$raclive <- labelled(gss$raclive,
labels = c("Yes" = 1, "No" = 2),
label = "Presence of racial diversity in the neighborhood")
gss$spanking <- labelled(gss$spanking,
labels = c("Strongly agree" = 1, "Agree" = 2, "Disagree" = 3, "Strongly disagree" = 4),
label = "Favoring spanking children to discipline")
